{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "flow-desktop",
  "version": "0.1.0",
  "identifier": "com.flow.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000/desktop",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "node scripts/static-export.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "Flow Desktop",
        "width": 1200,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "devCsp": "default-src 'self'; connect-src 'self' http://localhost:3000 ws://localhost:3000; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
