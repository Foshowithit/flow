{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-schema/refs/heads/main/schema.json",
  "productName": "flow-desktop",
  "version": "0.1.0",
  "identifier": "com.flow.desktop",
  "build": {
    "frontendDist": "../scripts",
    "devUrl": "https://web-sigma-khaki-61.vercel.app/desktop",
    "beforeDevCommand": "",
    "beforeBuildCommand": "echo 'skip'"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Flow Desktop",
        "width": 1200,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "15.0"
    }
  }
}
