# ─── Web App Environment ──────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env or .env.local files.

# ─── Clerk (Auth) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/chat
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/chat

# ─── Stripe (Payments) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_ID_PRO=
NEXT_PUBLIC_STRIPE_PRICE_ID_ENTERPRISE=

# ─── Database (Neon) ──────────────────────────────────────────────────────────
DATABASE_URL=
DATABASE_URL_UNPOOLED=
DATABASE_POOLED_URL=

# ─── DeepSeek AI ──────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ─── OpenCode Go AI (Beta) ────────────────────────────────────────────
# Use OpenCode Go as the LLM provider instead of DeepSeek.
# When set, base URL becomes https://opencode.ai/zen/go/v1 and model names
# use the OpenCode Go format (deepseek/deepseek-v4-flash, deepseek/deepseek-v4-pro).
#OPENCODE_GO_API_KEY=

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
MOCK_CHAT=true
APP_ENV=development

# ─── Existing (Bridge / Legacy) ───────────────────────────────────────────────
JOHN_BRIDGE_URL=http://localhost:3092/v1/chat/completions
JOHN_BRIDGE_API_KEY=br-your-key-here
JOHN_MODEL_NAME=Flow Assistant
