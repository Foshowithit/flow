# ─── Clerk Authentication ───────────────────────────
# Required for web mode. Desktop mode uses guest fallback.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─── Database ────────────────────────────────────────
# PostgreSQL connection string (Neon or local)
DATABASE_URL=postgresql://flow:flow@localhost:5432/flow

# ─── LLM Gateway ────────────────────────────────────
# Points to the LiteLLM gateway service
NEXT_PUBLIC_GATEWAY_URL=http://localhost:4000

# ─── OpenCode Go (default provider for guest / default users) ──
# Set this to the OpenCode Go API key for guest and default-user chat
OPENCODE_GO_API_KEY=placeholder-opencode-go-key-change-me

# ─── Optional: Admin API Key ────────────────────────
# ADMIN_API_KEY=your-admin-key

# ─── Optional: Application URL ──────────────────────
# Used by webhooks and Tauri production builds
# NEXT_PUBLIC_APP_URL=https://web-sigma-khaki-61.vercel.app

# ─── Embeddings (Gemini) ──────────────────────────────
# Required for memory extraction and RAG vector search
# Uses Gemini text-embedding-004 (768d)
GEMINI_API_KEY=your-gemini-api-key
