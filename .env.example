# Flow Gateway — Environment Variables (copy to .env and fill)
# WARNING: Never commit .env to version control.

# Master key for administrative endpoints (health, model management)
FLOW_MASTER_KEY=placeholder-flow-master-key-change-me

# Salt used for deterministic model/request identifiers
FLOW_SALT_KEY=placeholder-salt-change-me

# PostgreSQL connection string (used by LiteLLM proxy)
DATABASE_URL=postgresql://flow:flow@flow-postgres:5432/flow

# --- Upstream Provider API Keys (see docs/service-strategy.md) ---

# Fireworks AI (primary working upstream for Flash models)
FIREWORKS_API_KEY=placeholder-fireworks-key-change-me

# DeepInfra (primary working upstream for Llama / fallback for Flash)
DEEPINFRA_API_KEY=placeholder-deepinfra-key-change-me

# Makora inference API (tertiary fallback / benchmark target — sold-out risk)
MAKORA_API_KEY=placeholder-makora-key-change-me

# --- Disabled until topped up (kept for reference) ---

# DeepSeek direct API (disabled — no credit)
DEEPSEEK_API_KEY=placeholder-deepseek-key-change-me

# OpenRouter fallback / multi-model router (disabled — no credit)
OPENROUTER_API_KEY=placeholder-openrouter-key-change-me
